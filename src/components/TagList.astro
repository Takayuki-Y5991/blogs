---
import type { Lang } from '../i18n/ui';
import { getPathPrefix } from '../i18n/utils';

interface Props {
  tags: string[];
  lang: Lang;
}

const { tags, lang } = Astro.props;
const prefix = getPathPrefix(lang);
---

<ul class="tag-list">
  {tags.map((tag) => (
    <li>
      <a href={`${prefix}/tags/${tag}`} class="tag-link">
        #{tag}
      </a>
    </li>
  ))}
</ul>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag-link {
    display: inline-block;
    padding: 3px 10px;
    background-color: var(--color-secondary);
    color: var(--color-text-muted);
    border-radius: 100px;
    font-size: 0.8rem;
    transition: all var(--transition-fast);
    cursor: pointer;
  }

  .tag-link:hover {
    background-color: var(--color-accent);
    color: var(--color-surface);
  }

  .tag-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
