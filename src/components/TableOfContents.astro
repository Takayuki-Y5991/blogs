---
export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  lang?: 'ja' | 'en';
}

const { headings, lang = 'ja' } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth >= 1 && h.depth <= 4);
const tocTitle = lang === 'ja' ? '目次' : 'Contents';
---

{filteredHeadings.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <h2 class="toc-title">{tocTitle}</h2>
    <ul class="toc-list">
      {filteredHeadings.map((heading) => (
        <li class={`toc-item toc-depth-${heading.depth}`}>
          <a href={`#${heading.slug}`} class="toc-link">
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    position: sticky;
    top: calc(var(--space-xl) + 60px);
    max-height: calc(100vh - var(--space-xl) - 80px);
    overflow-y: auto;
    padding: var(--space-lg);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .toc::-webkit-scrollbar {
    width: 3px;
  }

  .toc::-webkit-scrollbar-track {
    background: transparent;
  }

  .toc::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 2px;
  }

  .toc-title {
    font-size: 0.85rem;
    font-family: var(--font-heading);
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin-bottom: 2px;
  }

  .toc-link {
    display: block;
    padding: 4px var(--space-sm);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    line-height: 1.5;
    border-right: 2px solid transparent;
    border-radius: 3px 0 0 3px;
    transition: all var(--transition-fast);
  }

  .toc-link:hover {
    color: var(--color-accent);
    background-color: rgba(139, 111, 71, 0.06);
    border-right-color: var(--color-accent);
  }

  .toc-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 3px;
  }

  .toc-depth-1 .toc-link { padding-left: var(--space-sm); font-weight: 600; }
  .toc-depth-2 .toc-link { padding-left: var(--space-md); }
  .toc-depth-3 .toc-link { padding-left: calc(var(--space-md) + var(--space-sm)); font-size: 0.78rem; }
  .toc-depth-4 .toc-link { padding-left: calc(var(--space-lg) + var(--space-sm)); font-size: 0.78rem; opacity: 0.8; }

  .toc-link.active {
    color: var(--color-accent);
    background-color: rgba(139, 111, 71, 0.08);
    border-right-color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 1200px) {
    .toc { display: none; }
  }
</style>

<script>
  function updateActiveHeading() {
    const headings = document.querySelectorAll('article h1[id], article h2[id], article h3[id], article h4[id]');
    const tocLinks = document.querySelectorAll('.toc-link');
    let activeHeading: Element | null = null;
    const scrollPosition = window.scrollY + 100;
    headings.forEach((heading) => {
      if (scrollPosition >= (heading as HTMLElement).offsetTop) {
        activeHeading = heading;
      }
    });
    tocLinks.forEach((link) => {
      link.classList.remove('active');
      if (activeHeading && link.getAttribute('href') === `#${activeHeading.id}`) {
        link.classList.add('active');
      }
    });
  }
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => { updateActiveHeading(); ticking = false; });
      ticking = true;
    }
  });
  updateActiveHeading();
</script>
