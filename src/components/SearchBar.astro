---
interface Props {
  lang: 'ja' | 'en';
}

const { lang } = Astro.props;
const placeholder = lang === 'ja' ? '記事を検索...' : 'Search posts...';
const noResults = lang === 'ja' ? '該当する記事が見つかりません' : 'No matching posts found';
---

<div class="search-container">
  <div class="search-input-wrapper">
    <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input
      type="search"
      class="search-input"
      placeholder={placeholder}
      aria-label={placeholder}
      data-no-results={noResults}
    />
    <kbd class="search-kbd" aria-hidden="true">/</kbd>
  </div>
  <p class="no-results-msg" hidden>{noResults}</p>
</div>

<style>
  .search-container {
    max-width: 480px;
    margin: 0 auto var(--space-lg);
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: var(--space-md);
    color: var(--color-text-muted);
    pointer-events: none;
    opacity: 0.6;
  }

  .search-input {
    width: 100%;
    padding: var(--space-sm) var(--space-lg) var(--space-sm) calc(var(--space-md) + 26px);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    outline: none;
    transition: all var(--transition-fast);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(139, 111, 71, 0.1);
  }

  .search-kbd {
    position: absolute;
    right: var(--space-md);
    padding: 2px 8px;
    font-family: var(--font-code);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background-color: var(--color-secondary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    opacity: 0.7;
  }

  .no-results-msg {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-style: italic;
    padding: var(--space-lg) 0;
    margin: 0;
  }
</style>

<script>
  const input = document.querySelector('.search-input') as HTMLInputElement;
  const noResultsMsg = document.querySelector('.no-results-msg') as HTMLElement;

  if (input) {
    // "/" key shortcut to focus search
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== input) {
        e.preventDefault();
        input.focus();
      }
    });

    // Hide kbd hint when focused
    const kbd = document.querySelector('.search-kbd') as HTMLElement;
    input.addEventListener('focus', () => { if (kbd) kbd.style.display = 'none'; });
    input.addEventListener('blur', () => { if (kbd && !input.value) kbd.style.display = ''; });

    input.addEventListener('input', () => {
      const query = input.value.toLowerCase().trim();
      const cards = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>;
      let visibleCount = 0;

      cards.forEach((card) => {
        const title = (card.dataset.title || '').toLowerCase();
        const desc = (card.dataset.description || '').toLowerCase();
        const tags = (card.dataset.tags || '').toLowerCase();

        const matches = !query || title.includes(query) || desc.includes(query) || tags.includes(query);
        card.style.display = matches ? '' : 'none';
        if (matches) visibleCount++;
      });

      if (noResultsMsg) {
        noResultsMsg.hidden = visibleCount > 0 || !query;
      }
    });
  }
</script>
