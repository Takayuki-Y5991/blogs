---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'ja' | 'en';
  categories: string[];
  tags: string[];
}

const { lang, categories, tags } = Astro.props;
const t = useTranslations(lang);

const searchPlaceholder = lang === 'ja' ? '記事を検索...' : 'Search posts...';
const noResultsText = lang === 'ja' ? '該当する記事が見つかりません' : 'No matching posts found';
const allText = lang === 'ja' ? 'すべて' : 'All';
const catHead = lang === 'ja' ? 'カテゴリー' : 'Categories';
const tagHead = lang === 'ja' ? 'タグ' : 'Tags';
---

<div class="blog-filter-section">
  <!-- Search Input -->
  <div class="search-container">
    <div class="search-input-wrapper">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="search"
        class="search-input"
        id="blogSearchInput"
        placeholder={searchPlaceholder}
        aria-label={searchPlaceholder}
      />
      <kbd class="search-kbd" aria-hidden="true">/</kbd>
    </div>
  </div>

  <!-- Filter Pills -->
  <div class="filter-groups">
    <!-- Categories -->
    <div class="filter-group">
      <h3 class="filter-heading">{catHead}</h3>
      <div class="filter-pills" id="categoryPills">
        <button class="filter-pill active" data-filter-type="category" data-value="all">{allText}</button>
        {categories.map(cat => (
          <button class="filter-pill" data-filter-type="category" data-value={cat}>
            {t(`category.${cat}`)}
          </button>
        ))}
      </div>
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="filter-group">
        <h3 class="filter-heading">{tagHead}</h3>
        <div class="filter-pills" id="tagPills">
          <button class="filter-pill active" data-filter-type="tag" data-value="all">{allText}</button>
          {tags.map(tag => (
            <button class="filter-pill" data-filter-type="tag" data-value={tag}>
              #{tag}
            </button>
          ))}
        </div>
      </div>
    )}
  </div>

  <p class="no-results-msg" id="noResultsMsg" hidden>{noResultsText}</p>
</div>

<style>
  .blog-filter-section {
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .search-container {
    margin-bottom: var(--space-lg);
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: var(--space-md);
    color: var(--color-text-muted);
    pointer-events: none;
    opacity: 0.6;
  }

  .search-input {
    width: 100%;
    padding: var(--space-sm) var(--space-lg) var(--space-sm) calc(var(--space-md) + 26px);
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background-color: var(--color-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    outline: none;
    transition: all var(--transition-fast);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .search-input:focus {
    border-color: var(--color-accent);
    background-color: var(--color-surface);
    box-shadow: 0 0 0 3px rgba(139, 111, 71, 0.1);
  }

  .search-kbd {
    position: absolute;
    right: var(--space-md);
    padding: 2px 8px;
    font-family: var(--font-code);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background-color: var(--color-secondary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    opacity: 0.7;
  }

  .filter-groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .filter-heading {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 4px 0;
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filter-pill {
    padding: 4px 14px;
    background-color: var(--color-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-pill:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-pill.active {
    background-color: var(--color-accent);
    color: var(--color-surface);
    border-color: var(--color-accent);
  }

  .no-results-msg {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-style: italic;
    padding: var(--space-xl) 0 0;
    margin: 0;
  }
</style>

<script>
  function setupFilters() {
    const searchInput = document.getElementById('blogSearchInput') as HTMLInputElement;
    const noResultsMsg = document.getElementById('noResultsMsg');
    const cards = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>;
    const pills = document.querySelectorAll('.filter-pill') as NodeListOf<HTMLButtonElement>;
    
    let currentCategory = 'all';
    let currentTag = 'all';
    let currentSearch = '';

    const filterPosts = () => {
      let visibleCount = 0;
      
      cards.forEach(card => {
        const title = (card.dataset.title || '').toLowerCase();
        const desc = (card.dataset.description || '').toLowerCase();
        const postCategory = card.dataset.category || '';
        const postTags = (card.dataset.tags || '').split(',');

        const matchSearch = !currentSearch || title.includes(currentSearch) || desc.includes(currentSearch) || postTags.some(t => t.toLowerCase().includes(currentSearch));
        const matchCategory = currentCategory === 'all' || postCategory === currentCategory;
        const matchTag = currentTag === 'all' || postTags.includes(currentTag);

        const isVisible = matchSearch && matchCategory && matchTag;
        
        if (isVisible) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (noResultsMsg) {
        noResultsMsg.hidden = visibleCount > 0;
      }
    };

    // Text search logic
    if (searchInput) {
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && document.activeElement !== searchInput) {
          e.preventDefault();
          searchInput.focus();
        }
      });

      const kbd = document.querySelector('.search-kbd') as HTMLElement;
      searchInput.addEventListener('focus', () => { if (kbd) kbd.style.display = 'none'; });
      searchInput.addEventListener('blur', () => { if (kbd && !searchInput.value) kbd.style.display = ''; });

      searchInput.addEventListener('input', (e) => {
        currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
        filterPosts();
      });
    }

    // Pill click logic
    pills.forEach(pill => {
      pill.addEventListener('click', (e) => {
        const type = pill.dataset.filterType;
        const value = pill.dataset.value || 'all';

        // Update active class state inside the group
        const group = pill.closest('.filter-pills');
        if (group) {
          group.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
          pill.classList.add('active');
        }

        if (type === 'category') currentCategory = value;
        if (type === 'tag') currentTag = value;

        filterPosts();
      });
    });
  }

  // Run on load and matching Astro's view transitions
  setupFilters();
  document.addEventListener('astro:page-load', setupFilters);
</script>
