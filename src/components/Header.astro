---
import type { Lang } from '../i18n/ui';
import { useTranslations, getPathPrefix } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = getPathPrefix(lang);
---

<header>
  <div class="header-container">
    <a href={`${prefix}/`} class="site-title">
      <span class="title-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 8h1a4 4 0 1 1 0 8h-1"/>
          <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/>
          <line x1="6" x2="6" y1="2" y2="4"/>
          <line x1="10" x2="10" y1="2" y2="4"/>
          <line x1="14" x2="14" y1="2" y2="4"/>
        </svg>
      </span>
      <span class="title-text">konkon.dev</span>
    </a>
    <nav aria-label="Main navigation">
      <a href={`${prefix}/`}>{t('nav.home')}</a>
      <a href={`${prefix}/blog`}>{t('nav.blog')}</a>
      <a href={`${prefix}/about`}>{t('nav.about')}</a>
      <LanguageSwitcher lang={lang} />
      <button class="theme-toggle" aria-label={lang === 'ja' ? 'テーマ切替' : 'Toggle theme'} type="button">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-md) 0;
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background-color: var(--header-bg);
  }

  .header-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .header-container {
      padding: 0 var(--space-lg);
    }
  }

  .site-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 3vw, 1.35rem);
    font-weight: 600;
    color: var(--color-text);
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .title-icon {
    display: flex;
    align-items: center;
    color: var(--color-accent);
    transition: transform var(--transition-normal);
  }

  .site-title:hover .title-icon {
    transform: rotate(-15deg) scale(1.1);
  }

  .site-title:hover {
    color: var(--color-accent);
  }

  .site-title:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  nav {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    nav {
      gap: var(--space-lg);
    }
  }

  nav a {
    color: var(--color-text-muted);
    font-size: clamp(0.875rem, 2vw, 1rem);
    font-weight: 500;
    position: relative;
    transition: color var(--transition-fast);
  }

  nav a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent-warm);
    border-radius: 1px;
    transition: width var(--transition-normal);
  }

  nav a:hover {
    color: var(--color-accent);
  }

  nav a:hover::after {
    width: 100%;
  }

  nav a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background: var(--color-secondary);
    color: var(--color-text-muted);
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-surface);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .icon-moon { display: none; }

  :global([data-theme='dark']) .icon-sun { display: none; }
  :global([data-theme='dark']) .icon-moon { display: block; }
</style>

<script>
  function getTheme(): string {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme')!;
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function setTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  }

  // Apply on load
  setTheme(getTheme());

  // Toggle button
  document.querySelector('.theme-toggle')?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    setTheme(current === 'dark' ? 'light' : 'dark');
  });

  // Listen for system preference changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      setTheme(e.matches ? 'dark' : 'light');
    }
  });
</script>
