---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import BlogFilter from '../../../components/BlogFilter.astro';
import { filterPostsByLang, useTranslations } from '../../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const posts = filterPostsByLang(allPosts, lang);
const sortedPosts = posts.sort((a, b) => 
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const totalPosts = sortedPosts.length;
const categories = [...new Set(sortedPosts.map(p => p.data.category))];
const allTags = [...new Set(sortedPosts.flatMap(p => p.data.tags))];
---

<BaseLayout
  title={`${t('post.allPosts')} - konkon.dev`}
  description="All blog posts"
  lang={lang}
>
  <div class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>{t('post.allPosts')}</h1>
      <p class="hero-subtitle">Exploring the vast digital landscape</p>
      <div class="post-count-badge">{totalPosts} Articles</div>
    </div>
  </div>

  <div class="blog-container">
    <BlogFilter lang={lang} categories={categories} tags={allTags} />
    
    <div class="post-grid">
      {sortedPosts.map((post) => (
        <PostCard post={post} lang={lang} />
      ))}
    </div>
  </div>
</BaseLayout>


<style>
  .hero {
    position: relative;
    margin: calc(-1 * var(--space-lg)) calc(-1 * var(--space-md)) var(--space-xl);
    padding: var(--space-xl) var(--space-md);
    background-image: url('/images/blog-hero.png');
    background-size: cover;
    background-position: center;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    overflow: hidden;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero {
      margin: calc(-1 * var(--space-xl)) calc(-1 * var(--space-lg)) var(--space-xl);
      padding: var(--space-xl) var(--space-lg);
      min-height: 300px;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(44, 36, 32, 0.85) 0%,
      rgba(44, 36, 32, 0.7) 50%,
      rgba(139, 111, 71, 0.75) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero h1 {
    color: #FFFFFF;
    margin-bottom: var(--space-sm);
    font-family: var(--font-heading);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    font-size: clamp(2.5rem, 8vw, 3.5rem);
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    font-style: italic;
    margin-bottom: var(--space-md);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }

  .post-count-badge {
    display: inline-block;
    padding: 4px 16px;
    background-color: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    color: #FFFFFF;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .blog-container {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    max-width: var(--content-width);
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
