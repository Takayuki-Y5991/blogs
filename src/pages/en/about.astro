---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en';
---

<BaseLayout
  title="About - konkon.dev"
  description="About this blog"
  lang={lang}
>
  <div class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>About</h1>
      <p class="hero-subtitle">Where Technology and Curiosity Intersect</p>
    </div>
  </div>

  <article class="about-container">
    <section class="about-section introduce">
      <h2>About This Blog</h2>
      <p>
        This is a personal tech blog focusing on HackTheBox writeups and programming language exploration.
      </p>
    </section>

    <section>
      <h2>Topics</h2>
      <details class="topic-toggle">
        <summary>HackTheBox Writeups</summary>
        <p>CTF challenges and security research</p>
      </details>
      <details class="topic-toggle">
        <summary>Daily AlpacaHack</summary>
        <p>Writeups for daily CTF challenges on <a href="https://alpacahack.com/" target="_blank" rel="noopener">AlpacaHack</a>. Covering crypto, web, reversing and more, documenting the approach and lessons learned from each problem.</p>
      </details>
      <details class="topic-toggle">
        <summary>Language Exploration</summary>
        <p>Deep dives into programming languages like Clojure</p>
      </details>
      <details class="topic-toggle">
        <summary>Misc</summary>
        <p>Various tech topics and thoughts</p>
      </details>
    </section>

    <section>
      <h2>Tech Stack</h2>
      <p>
        This blog is built with Astro v5.x, TypeScript, and deployed as a static site.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .hero {
    position: relative;
    margin: calc(-1 * var(--space-lg)) calc(-1 * var(--space-md)) var(--space-xl);
    padding: var(--space-xl) var(--space-md);
    background-image: url('/images/about-hero.png');
    background-size: cover;
    background-position: center;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    overflow: hidden;
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero {
      margin: calc(-1 * var(--space-xl)) calc(-1 * var(--space-lg)) var(--space-xl);
      padding: var(--space-xl) var(--space-lg);
      min-height: 280px;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(44, 36, 32, 0.8) 0%,
      rgba(44, 36, 32, 0.6) 50%,
      rgba(139, 111, 71, 0.7) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero h1 {
    color: #FFFFFF;
    margin-bottom: var(--space-sm);
    font-family: var(--font-heading);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    font-size: 3.5rem;
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    font-style: italic;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }

  .about-container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .about-section {
    margin-bottom: var(--space-xxl);
  }

  h2 {
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  h2::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 2px;
    background-color: var(--color-accent);
    opacity: 0.3;
  }

  p {
    line-height: 1.8;
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  .topic-toggle {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-md);
    overflow: hidden;
    background-color: var(--color-surface);
    transition: all var(--transition-normal);
  }

  .topic-toggle:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
  }

  .topic-toggle summary {
    padding: var(--space-md);
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text);
    background-color: var(--color-secondary);
    transition: background-color var(--transition-fast);
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .topic-toggle summary::before {
    content: "▸";
    display: inline-block;
    transition: transform var(--transition-fast);
    color: var(--color-accent);
  }

  .topic-toggle[open] summary::before {
    transform: rotate(90deg);
  }

  .topic-toggle summary::-webkit-details-marker {
    display: none;
  }

  .topic-toggle p {
    padding: var(--space-md) var(--space-lg);
    margin: 0;
    border-top: 1px solid var(--color-border);
    font-size: 0.95rem;
  }

  .stack-info {
    padding: var(--space-lg);
    background-color: var(--color-secondary);
    border-radius: var(--radius-md);
    border: 1px dashed var(--color-border);
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .stack-tags span {
    padding: 4px 12px;
    background-color: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-accent);
  }
</style>
