---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en';
---

<BaseLayout
  title="About - konkon.dev"
  description="About this blog"
  lang={lang}
>
  <article class="about-content">
    <h1>About</h1>
    
    <section>
      <h2>About This Blog</h2>
      <p>
        This is a personal tech blog focusing on HackTheBox writeups and programming language exploration.
      </p>
    </section>

    <section>
      <h2>Topics</h2>
      <details class="topic-toggle">
        <summary>HackTheBox Writeups</summary>
        <p>CTF challenges and security research</p>
      </details>
      <details class="topic-toggle">
        <summary>Daily AlpacaHack</summary>
        <p>Writeups for daily CTF challenges on <a href="https://alpacahack.com/" target="_blank" rel="noopener">AlpacaHack</a>. Covering crypto, web, reversing and more, documenting the approach and lessons learned from each problem.</p>
      </details>
      <details class="topic-toggle">
        <summary>Language Exploration</summary>
        <p>Deep dives into programming languages like Clojure</p>
      </details>
      <details class="topic-toggle">
        <summary>Misc</summary>
        <p>Various tech topics and thoughts</p>
      </details>
    </section>

    <section>
      <h2>Tech Stack</h2>
      <p>
        This blog is built with Astro v5.x, TypeScript, and deployed as a static site.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .about-content {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  h1 {
    margin-bottom: var(--space-lg);
  }

  section {
    margin-bottom: var(--space-xl);
  }

  h2 {
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  p {
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  ul {
    list-style: none;
    padding-left: 0;
  }

  li {
    margin-bottom: var(--space-sm);
    padding-left: var(--space-md);
    position: relative;
  }

  li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  strong {
    color: var(--color-accent);
  }

  .topic-toggle {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-sm);
    overflow: hidden;
  }

  .topic-toggle summary {
    padding: var(--space-sm) var(--space-md);
    cursor: pointer;
    font-weight: 600;
    color: var(--color-accent);
    background-color: var(--color-secondary);
    transition: background-color var(--transition-fast);
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .topic-toggle summary::before {
    content: "▸";
    display: inline-block;
    transition: transform var(--transition-fast);
  }

  .topic-toggle[open] summary::before {
    transform: rotate(90deg);
  }

  .topic-toggle summary::-webkit-details-marker {
    display: none;
  }

  .topic-toggle summary:hover {
    background-color: var(--color-cream);
  }

  .topic-toggle p {
    padding: var(--space-md);
    margin: 0;
    border-top: 1px solid var(--color-border);
  }

  .topic-toggle a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
